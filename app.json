{
  "expo": {
    "scheme": "savva",
    "name": "savva",
    "slug": "savva",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/savva-logo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/savva-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1B2E"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/savva-logo.png",
        "backgroundColor": "#1A1B2E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.savva"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-router"
    ]
  }
}
